{
  "name": "@redgreen-labs/forge-cli",
  "version": "0.2.2",
  "description": "Autonomous multi-agent development orchestrator with TDD, security, and craftsmanship",
  "type": "module",
  "bin": {
    "forge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration/ --testTimeout=300000",
    "test:smoke": "SMOKE=1 vitest run tests/integration/cli-smoke.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "npm audit --audit-level=moderate",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "npm run typecheck && npm run lint && npm run test && npm run test:security",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "autonomous",
    "development",
    "tdd",
    "multi-agent",
    "security",
    "forge"
  ],
  "author": "Red Green Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/redgreenlabs/forge-cli"
  },
  "homepage": "https://redgreenlabs.github.io/forge-cli",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-table": "^3.1.0",
    "pino": "^9.4.0",
    "react": "^18.3.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
