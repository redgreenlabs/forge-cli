{
  "name": "@redgreen-labs/forge-cli",
  "version": "0.2.4",
  "description": "Autonomous multi-agent development orchestrator with TDD, security, and craftsmanship",
  "type": "module",
  "bin": {
    "forge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:smoke": "SMOKE=1 vitest run --config vitest.integration.config.ts tests/integration/cli-smoke.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "npm audit --audit-level=moderate",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "npm run typecheck && npm run lint && npm run test && npm run test:security",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "autonomous",
    "development",
    "tdd",
    "multi-agent",
    "security",
    "forge"
  ],
  "author": "Red Green Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/redgreenlabs/forge-cli"
  },
  "homepage": "https://redgreenlabs.github.io/forge-cli",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
